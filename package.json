{
  "name": "laravel-tutor",
  "displayName": "Laravel Tutor",
  "description": "Laravel 13 inline hints for beginners — Bilingual ID/EN",
  "version": "1.0.0",
  "publisher": "AxonLabs",
  "license": "MIT",
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#FF2D20",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AxonLabs/laravel-tutor.git"
  },
  "bugs": {
    "url": "https://github.com/AxonLabs/laravel-tutor/issues"
  },
  "homepage": "https://github.com/AxonLabs/laravel-tutor#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "laravel",
    "php",
    "laravel 13",
    "tutorial",
    "indonesia",
    "beginner",
    "laravel tutorial",
    "php hints",
    "code education",
    "ghost text",
    "tooltip",
    "inline documentation",
    "laravel helper",
    "php learning"
  ],
  "activationEvents": [
    "onLanguage:php",
    "onView:laravelTutor.checklist"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Laravel Tutor",
      "properties": {
        "laravelTutor.language": {
          "type": "string",
          "enum": [
            "id",
            "en"
          ],
          "default": "id",
          "description": "Language for Laravel Tutor hints (id for Bahasa Indonesia, en for English)"
        }
      }
    },
    "commands": [
      {
        "command": "laravelTutor.toggleLanguage",
        "title": "Laravel Tutor: Toggle Language"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laravelTutorSidebar",
          "title": "Laravel Tutor",
          "icon": "$(code)"
        }
      ]
    },
    "views": {
      "laravelTutorSidebar": [
        {
          "type": "webview",
          "id": "laravelTutor.checklist",
          "name": "Checklist"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
